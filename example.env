# Environment variables for the Recipe Book workshop.
#
# Copy this file to `.env`, then fill in the value below:
#
#     cp example.env .env
#
# `.env` is gitignored, so your token is never committed.

# API token for the ask-ai service. Only the `ai-proxy` container reads this;
# it injects the token when forwarding requests, so the coding agent and the
# backend never see it. You'll be given this token for the workshop.
ASKAI_API_TOKEN=
