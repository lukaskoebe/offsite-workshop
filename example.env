# Environment variables for the Recipe Book workshop.
#
# Copy this file to `.env`, then fill in the value below:
#
#     cp example.env .env
#
# `.env` is gitignored, so your token is never committed.

# API token for the AI coding agent (used by the `opencode` service via the
# ask-ai provider). You'll be given this token for the workshop.
ASKAI_API_TOKEN=
