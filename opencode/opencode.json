{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "ask-ai"
  ],
  "model": "ask-ai/vllm/coding",
  "provider": {
    "ask-ai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ask-ai",
      "options": {
        "baseURL": "http://ai-proxy:8080/api",
        "apiKey": "proxy-injects-token"
      },
      "models": {
        "vllm/generic": {
          "name": "Generic",
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          }
        } ,
        "vllm/coding": {
          "name": "Coder",
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          }
        },
        "vllm/deepseek": {
          "name": "Deepseek",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  }
}

